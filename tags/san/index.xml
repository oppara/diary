<?xml version="1.0" encoding="utf-8" standalone="yes"?><rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom" xmlns:content="http://purl.org/rss/1.0/modules/content/"><channel><title>San on d.oppara.tv</title><link>https://d.oppara.tv/tags/san/</link><description>Recent content in San on d.oppara.tv</description><generator>Hugo -- 0.148.2</generator><language>ja</language><lastBuildDate>Tue, 10 Mar 2026 22:27:57 +0900</lastBuildDate><atom:link href="https://d.oppara.tv/tags/san/index.xml" rel="self" type="application/rss+xml"/><item><title>openssl で SAN を確認</title><link>https://d.oppara.tv/posts/2026/03/openssl-check-san/</link><pubDate>Tue, 10 Mar 2026 22:27:57 +0900</pubDate><guid>https://d.oppara.tv/posts/2026/03/openssl-check-san/</guid><description>&lt;h2 id="はじめに">はじめに&lt;/h2>
&lt;p>手元の証明書ファイルから Subject Alternative Name (SAN) を確認するための備呆録。&lt;/p>
&lt;h2 id="やり方">やり方&lt;/h2>
&lt;div class="highlight">&lt;pre tabindex="0" style="color:#f8f8f2;background-color:#272822;-moz-tab-size:4;-o-tab-size:4;tab-size:4;">&lt;code class="language-shell" data-lang="shell">&lt;span style="display:flex;">&lt;span>openssl x509 -noout -text -in /path/to/cert.pem | grep -A1 &lt;span style="color:#e6db74">&amp;#34;Subject Alternative Name&amp;#34;&lt;/span>
&lt;/span>&lt;/span>&lt;/code>&lt;/pre>&lt;/div>&lt;h2 id="環境">環境&lt;/h2>
&lt;div class="highlight">&lt;pre tabindex="0" style="color:#f8f8f2;background-color:#272822;-moz-tab-size:4;-o-tab-size:4;tab-size:4;">&lt;code class="language-console" data-lang="console">&lt;span style="display:flex;">&lt;span>% sw_vers
&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span>ProductName: macOS
&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span>ProductVersion: 26.3
&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span>BuildVersion: 25D125
&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span>&lt;span style="color:#960050;background-color:#1e0010">
&lt;/span>&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span>&lt;span style="color:#960050;background-color:#1e0010">&lt;/span>% openssl version
&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span>OpenSSL 3.6.1 27 Jan 2026 (Library: OpenSSL 3.6.1 27 Jan 2026)
&lt;/span>&lt;/span>&lt;/code>&lt;/pre>&lt;/div></description></item></channel></rss>